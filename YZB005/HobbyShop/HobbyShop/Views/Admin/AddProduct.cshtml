@model List<HobbyShop.Models.Product>

<div style="display:flex; gap:30px; align-items:flex-start;">

    <!-- SOL FORM -->
    <div style="
        width:320px;
        background:white;
        padding:20px;
        border-radius:12px;
        box-shadow:0 4px 10px rgba(0,0,0,0.1);">

        <h2>Ürün Ekle ➕</h2>

        <form method="post">

            <label>Ürün Adı:</label>
            <input type="text"
                   name="name"
                   placeholder="Ürün Adı"
                   required
                   style="width:100%; padding:10px; margin-bottom:10px;" />

            <label>Resim URL:</label>
            <input type="text"
                   name="imageUrl"
                   placeholder="https://..."
                   style="width:100%; padding:10px; margin-bottom:10px;" />

            <label>Açıklama:</label>
            <input type="text"
                   name="description"
                   required
                   style="width:100%; padding:10px; margin-bottom:10px;" />

            <label>Fiyat:</label>
            <input type="number"
                   name="price"
                   step="0.01"
                   required
                   style="width:100%; padding:10px; margin-bottom:10px;" />

            <label>Stok:</label>
            <input type="number"
                   name="stock"
                   required
                   style="width:100%; padding:10px; margin-bottom:10px;" />

            <label>Kategori:</label>

            <select name="categoryId"
                    required
                    style="width:100%; padding:10px; margin-bottom:20px;">

                <option value="1">Spor</option>
                <option value="2">Sanat</option>
                <option value="3">Müzik</option>
                <option value="4">Zeka Oyunları</option>

            </select>

            <button class="btn" type="submit">
                Ürün Ekle
            </button>

        </form>

    </div>

    <!-- SAĞ ÜRÜNLER -->
    <div style="flex:1;">

        <h2>Ürün Yönetimi 📦</h2>

        <div style="display:flex; flex-wrap:wrap; gap:20px;">

            @foreach (var item in Model)
            {
                <div class="card">

                    <img src="@item.ImageUrl"
                         style="
                             width:100%;
                             height:180px;
                             object-fit:cover;
                             border-radius:10px;
                             margin-bottom:10px;" />

                    <div class="card-title">
                        @item.ProductName
                    </div>

                    <div class="card-price">
                        @item.Price ₺
                    </div>

                    <p>Stok: @item.Stock</p>

                    <div style="display:flex; gap:10px; margin-top:10px;">

                        <a class="btn"
                           href="/Admin/EditProduct/@item.ProductID">
                            Düzenle
                        </a>

                        <a class="btn"
                           href="/Admin/DeleteProduct/@item.ProductID">
                            Sil
                        </a>

                    </div>

                </div>
            }

        </div>

    </div>

</div>